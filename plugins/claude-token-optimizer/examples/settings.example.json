{
  "model": "sonnet",
  "effortLevel": "medium",
  "statusLine": {
    "type": "command",
    "command": "claude-token-statusline"
  },
  "permissions": {
    "deny": [
      "Read(./node_modules/**)",
      "Read(./dist/**)",
      "Read(./build/**)",
      "Read(./coverage/**)",
      "Read(./logs/**)",
      "Read(./tmp/**)",
      "Read(./target/**)",
      "Read(./.next/**)",
      "Read(./.venv/**)",
      "Read(./vendor/**)",
      "Read(./.npmrc)",
      "Read(./.pypirc)",
      "Read(./.netrc)",
      "Read(./.claude-token-optimizer/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claude-token-rewrite-bash"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "claude-token-guard-read"
          }
        ]
      }
    ]
  }
}
